# Agent Watch Server Configuration
# Copy to .env, fill in values, chmod 600 .env — NEVER commit .env to git

# Required: Your AI provider API key
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Required: Static bearer token for Watch app authentication
# Generate with: python3 ../scripts/gen_token.py
AUTH_TOKEN=REPLACE_ME_WITH_GENERATED_TOKEN

# Optional: AI model to use (defaults to claude-haiku-4-5-20251001 for speed)
AI_MODEL=claude-haiku-4-5-20251001

# Optional: Max response tokens (default 2048)
MAX_TOKENS=2048

# Optional: Log level (DEBUG shows query text — use INFO in production)
LOG_LEVEL=INFO

# Optional: Rate limit — queries per minute per token (default 20)
RATE_LIMIT_QPM=20

# Optional: AI provider (default: anthropic; future: ollama, openai)
AI_PROVIDER=anthropic
